# Hugging Face API Configuration
HF_API_TOKEN=hf_xxxYYY                              # Your HF token (optional for local models)
USE_HF_API=False                                     # True to use HF Inference API, False for local

# Model Configuration
LOCAL_MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0  # Local model to use
# Alternative models:
# LOCAL_MODEL_NAME=microsoft/phi-2
# LOCAL_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.1

# Output Configuration
OUTPUT_DIR=output/qlora_tuned_model

# Chunking Parameters
MAX_CHUNK_TOKENS=800                                 # Maximum tokens per chunk
MIN_CHUNK_TOKENS=200                                 # Minimum tokens per chunk

# Processing Configuration
BATCH_SIZE=1                                         # Batch size for generation
NUM_WORKERS=4                                        # Number of worker threads

# Training Configuration (for train_lora.py)
LORA_R=8                                            # LoRA rank
LORA_ALPHA=16                                       # LoRA alpha
LEARNING_RATE=2e-4                                  # Learning rate
NUM_TRAIN_EPOCHS=3                                  # Number of training epochs
MAX_SEQ_LENGTH=512                                  # Maximum sequence length
PER_DEVICE_TRAIN_BATCH_SIZE=4                       # Per-device training batch size

# Generation Parameters
TEMPERATURE=0.1                                     # Lower = more deterministic
MAX_NEW_TOKENS=1024                                 # Max tokens to generate per chunk
TOP_P=0.95                                          # Nucleus sampling parameter
