# Example .env configuration for connecting Vercel to Hugging Face Spaces

# Tell the app to use external API instead of loading the model locally
USE_HF_API=True

# OPTION 1: Use a deployed Hugging Face Space (Recommended for custom models/scripts)
# Replace with the direct API URL of your deployed Space
HF_SPACE_URL=https://your-username-your-space-name.hf.space/api/generate

# OPTION 2: Use Hugging Face Inference API directly (If model is just uploaded to Hub)
# Replace with your model repository
# HF_MODEL_ID=your-username/vedlinks-model

# Your Hugging Face Access Token (Required for private spaces or models)
HF_API_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
